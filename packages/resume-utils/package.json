{
  "name": "@lianqq/resume-utils",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./es/index.js",
      "require": "./lib/index.js",
